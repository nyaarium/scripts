{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["bun-types"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true
	},
	"include": ["src", "eslint.config.js"],
	"exclude": [
		".claude",
		".cursor",
		".yarn",
		"build",
		"coverage",
		"node_modules",
		"volumes",
		".eslintrc.js",
		".pnp.cjs",
		".pnp.loader.mjs",
		"tsconfig.json"
	]
}
